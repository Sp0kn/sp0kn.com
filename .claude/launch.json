{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Frontend (Vite)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "port": 5173
    },
    {
      "name": "Backend (FastAPI)",
      "runtimeExecutable": "cmd",
      "runtimeArgs": ["/c", "cd backend && python -m uvicorn app.main:app --reload --port 8000"],
      "port": 8000
    }
  ]
}
